DATABASE_URL="postgresql://persiapanel:changeme@localhost:5432/persiapanel"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=3000

# System paths (defaults match Ubuntu 24.04 layout)
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
PHP_FPM_POOL_DIR_TEMPLATE=/etc/php/{version}/fpm/pool.d
SYSTEMD_UNIT_DIR=/etc/systemd/system
PANEL_WEBROOT=/home
ACME_HOME=/opt/acme.sh
ACME_WEBROOT_DIR=/var/www/acme-challenge
SSL_CERT_DIR=/etc/nginx/ssl
BACKUP_DIR=/var/backups/persia-panel

# One-click app installer (WordPress/phpMyAdmin). Bump the timeout on slow
# links; override the download URLs to point at a mirror if the upstream
# host is unreachable from an Iranian IP (same escape hatch as HTTPS_PROXY).
APP_INSTALL_DOWNLOAD_TIMEOUT_SECONDS=300
# WORDPRESS_DOWNLOAD_URL=https://wordpress.org/latest.tar.gz
# PHPMYADMIN_DOWNLOAD_URL=https://files.phpmyadmin.net/phpMyAdmin/5.2.1/phpMyAdmin-5.2.1-all-languages.tar.gz

# Fallback connectivity: where the admin-configured SSH tunnel's private key
# and known_hosts file are stored (0600/0700 permissions, never in the DB).
SSH_TUNNEL_KEY_DIR=/etc/persia-panel/ssh-tunnel

# Offsite backups: where the admin-configured backup destination's private
# key and known_hosts file are stored (0600/0700 permissions, never in the
# DB) — same invariant as SSH_TUNNEL_KEY_DIR above. Every completed local
# backup is best-effort rsync'd here over SSH once a destination is saved
# from the panel's Backups section.
BACKUP_DESTINATION_KEY_DIR=/etc/persia-panel/backup-destination

# DNS (BIND9 authoritative zones). NS_HOSTNAMES is a comma-separated list of
# nameserver hostnames written into every zone's NS/SOA records. Leave it
# empty to have each domain use this panel itself as its nameservers
# (ns1.<domain>/ns2.<domain>) — BIND refuses to load a zone with no NS
# records at all, so this can't actually be left blank/skipped. Set it only
# if you have your own separate nameserver hostnames to advertise instead.
# SERVER_PUBLIC_IP, if set, is used to auto-seed a default "@"/"www" A record
# when a domain is created, and to glue the ns1/ns2 fallback above to an
# actual address — leave unset to skip auto-seeding and manage records
# manually (the zone will still load fine without it).
BIND_ZONES_DIR=/etc/bind/zones
BIND_CONFIG_DIR=/etc/bind
DNS_DEFAULT_TTL=3600
DNS_NS_HOSTNAMES=
# SERVER_PUBLIC_IP=203.0.113.10

# Email (Postfix virtual mailboxes + Dovecot passwd-file auth). Mailbox
# passwords are never stored in Postgres — only Dovecot's own on-disk
# passwd file holds the credential, same invariant as SSH_TUNNEL_KEY_DIR.
POSTFIX_VIRTUAL_DOMAINS_FILE=/etc/postfix/vmail_domains
POSTFIX_VIRTUAL_MAILBOX_FILE=/etc/postfix/vmail_mailbox
DOVECOT_PASSWD_FILE=/etc/dovecot/vmail_passwd
MAIL_STORAGE_DIR=/var/mail/vhosts
VMAIL_UID=5000
VMAIL_GID=5000

# Used only by prisma/seed.ts to bootstrap the first admin account
ADMIN_EMAIL=admin@localhost
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
